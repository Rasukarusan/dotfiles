prefix_rule(pattern=["git", "remote", "-v"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo 'NO_UPSTREAM'"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "gh auth status 2>&1 || true"], decision="allow")
prefix_rule(pattern=["xargs", "pnpm", "format:check", "--ignore-unknown"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/app-graphql-server", "exec", "eslint", "src/infrastructures/repositories/mysql/ai-setting.repository.ts", "src/infrastructures/repositories/mysql/ai-setting.repository.spec.ts", "src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
