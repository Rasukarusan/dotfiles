prefix_rule(pattern=["pnpm", "--filter=@qast/app-graphql-server", "run", "test", "src/modules/concern-chat-ai/usecases/concern-chat-ai-answer.usecase.spec.ts"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/app-graphql-server", "run", "typecheck"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/app-graphql-server", "exec", "prettier", "--check", "src/modules/ai-settings/usecases/ai-setting-update.usecase.ts", "src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/app-graphql-server", "run", "test", "src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/authz", "run", "build"], decision="allow")
prefix_rule(pattern=["pnpm", "exec", "prettier", "--check", "libraries/authz/src/types.ts", "libraries/authz/src/core/subjects/index.ts", "libraries/authz/src/core/subjects/ai-setting-policy.ts", "libraries/authz/src/core/subjects/ai-setting-policy.spec.ts", "apps/app-graphql-server/src/modules/ai-settings/usecases/ai-setting-update.usecase.ts", "apps/app-graphql-server/src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/authz", "run", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/app-graphql-server", "exec", "eslint", "src/modules/ai-settings/usecases/ai-setting-update.usecase.ts", "src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
prefix_rule(pattern=["pnpm", "--filter=@qast/authz", "run", "lint"], decision="allow")
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["git", "ls-files", "libraries/authz/dist", "libraries/authz/temp"], decision="allow")
prefix_rule(pattern=["pnpm", "exec", "prettier", "--check", "apps/app-graphql-server/src/modules/ai-settings/usecases/ai-setting-update.usecase.ts", "apps/app-graphql-server/src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
