prefix_rule(pattern=["git", "commit", "-m", "fix: AI設定の新規保存時に確定IDを返す"], decision="allow")
prefix_rule(pattern=["git", "add", "apps/app-graphql-server/src/modules/ai-settings/usecases/ai-setting-update.usecase.spec.ts"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m", "test: AI設定更新時のバリデーションエラー期待値を修正"], decision="allow")
