#!/usr/bin/env bash
#
# 過去の Claude Code 会話履歴を fzf(popup) で一覧・プレビューし、選んだものを
# `claude --resume` で再開するためのピッカー。一覧/抽出は自作、プレビュー描画は fzf-preview(glow)。
#
# `claude --resume` と同じく、カレントディレクトリのセッションのみを対象にする。
# 履歴は ~/.claude/projects/<エンコードされたcwd>/<session-id>.jsonl に保存される
# (ディレクトリ名は cwd の英数字以外を - に置換したもの)。
#
# サブコマンド:
#   claude-resume-picker                対話モード。選択した sessionId を出力
#   claude-resume-picker list [cwd]     fzf 用の一覧を出力 (内部用)
#   claude-resume-picker preview <jsonl>  プレビュー本文を出力 (内部用)
set -euo pipefail

PROJECTS_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects"

# cwd -> プロジェクトディレクトリ(絶対パス)。英数字以外を - に置換。
project_dir() {
  printf '%s/%s' "$PROJECTS_DIR" "$(printf '%s' "$1" | sed 's/[^a-zA-Z0-9]/-/g')"
}

# 1セッション(jsonl)の表示ラベル「[branch] タイトル」を取り出す。
# タイトルは customTitle(ユーザー命名,📌付き) → ai-title → 最初の発言 → 最終プロンプト。
session_meta() {
  jq -rs '
    def clean: gsub("[\n\t]+";" ");
    (map(select(.type=="custom-title").customTitle)|map(select(. != null and . != ""))|last) as $ct
    | (map(select(.type=="ai-title").aiTitle)|last) as $t
    | (map(select(.type=="last-prompt").lastPrompt)|last) as $lp
    | (map(select(.gitBranch!=null).gitBranch)|last) as $br
    | (map(select(.type=="user")
          | .message.content
          | if type=="string" then .
            else (map(select(.type=="text") | .text? // "")|join(" ")) end)
       | map(select(. != null and . != "" and (startswith("<")|not)))
       | .[0]) as $u
    | (if $ct != null then "📌 " + $ct else ($t // $u // $lp // "(untitled)") end) as $title
    | ("[" + ($br // "-") + "] " + $title | clean)
  ' "$1" 2>/dev/null
}

# fzf 用の一覧を出力する。各行: <jsonlパス>\t<日時>\t<ラベル>
cmd_list() {
  local base="${1:-$PWD}"
  local dir f epoch disp label
  dir="$(project_dir "$base")"
  [ -d "$dir" ] || return 0
  find "$dir" -maxdepth 1 -name '*.jsonl' -type f 2>/dev/null | while IFS= read -r f; do
    [ -s "$f" ] || continue
    epoch=$(stat -f '%m' "$f")
    disp=$(stat -f '%Sm' -t '%m/%d %H:%M' "$f")
    label=$(session_meta "$f")
    [ -z "$label" ] && label="(untitled)"
    printf '%s\t%s\t%s\t%s\n' "$epoch" "$f" "$disp" "$label"
  done | sort -t$'\t' -k1,1nr | cut -f2-
}

# プレビュー本文(会話のトランスクリプト)を Markdown で出力。
# glow の全文描画は重い(数千行で1秒超)ため、先頭をすぐ描画し残りを後追いで描画する。
# fzf は preview の出力をストリーム表示するので、2回に分けて流すと体感が大きく速くなる。
# 行数で切るとコードブロック途中で崩れるので、メッセージ境界(👦/🤖 行)で分割する。
PREVIEW_HEAD_LINES=100
cmd_preview() {
  local f="$1"
  [ -s "$f" ] || { echo "(no content)"; return; }
  local md
  md=$(jq -r '
    select(.type=="user" or .type=="assistant")
    | (.message.role) as $role
    | (.message.content) as $c
    | (if ($c|type)=="string" then $c
       elif ($c|type)=="array" then
         [ $c[] | if .type=="text" then .text
                  elif .type=="tool_use" then "🔧 **"+(.name//"tool")+"**"
                  else empty end ] | join("\n\n")
       else "" end) as $text
    | select(($text|type)=="string" and $text != ""
             and ($text|ltrimstr(" ")|startswith("<")|not))
    | "\n" + (if $role=="user" then "👦 " else "🤖 " end) + $text
  ' "$f" 2>/dev/null)
  [ -z "$md" ] && { jq -r '.' "$f" 2>/dev/null; return; }

  # PREVIEW_HEAD_LINES 行以降で最初のメッセージ境界(👦/🤖 行)を分割点にする。
  local split
  split=$(printf '%s\n' "$md" \
    | grep -nE '^(👦|🤖)' \
    | awk -F: -v n="$PREVIEW_HEAD_LINES" '$1>n {print $1-1; exit}')

  if [ -n "$split" ]; then
    # head/tail はパイプを早期クローズし printf に SIGPIPE を起こす(pipefail+set -e で中断)。
    # sed は stdin を読み切るので安全。
    printf '%s\n' "$md" | sed -n "1,${split}p"        | fzf-preview -  # 先頭: 即描画
    printf '%s\n' "$md" | sed -n "$((split+1)),\$p"   | fzf-preview -  # 残り: 後追い描画
  else
    printf '%s\n' "$md" | fzf-preview -
  fi
}

# 対話モード。選択した sessionId を出力する。
cmd_interactive() {
  local self="$0"
  local fzf_opts=(
    --ansi
    --delimiter='\t'
    --with-nth='2..'
    --no-multi
    --prompt='resume> '
    --header='Enter: resume'
    --preview="$self preview {1}"
    --preview-window='right,50%,border-left,wrap'
  )
  [ -n "${TMUX:-}" ] && fzf_opts+=(--tmux 'center,90%,90%')

  local sel file
  sel=$(cmd_list "$PWD" | fzf "${fzf_opts[@]}") || return 0
  [ -z "$sel" ] && return 0
  file=${sel%%$'\t'*}
  basename "$file" .jsonl
}

case "${1:-}" in
  list) shift; cmd_list "$@" ;;
  preview) shift; cmd_preview "$@" ;;
  *) cmd_interactive ;;
esac
