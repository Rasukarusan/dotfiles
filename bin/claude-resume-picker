#!/usr/bin/env bash
#
# 過去の Claude Code 会話履歴を fzf(popup) で一覧・プレビューし、選んだものを
# `claude --resume` で再開するためのピッカー。一覧/抽出は自作、プレビュー描画は fzf-preview(glow)。
#
# `claude --resume` と同じく、カレントディレクトリのセッションのみを対象にする。
# 履歴は ~/.claude/projects/<エンコードされたcwd>/<session-id>.jsonl に保存される
# (ディレクトリ名は cwd の英数字以外を - に置換したもの)。
#
# サブコマンド:
#   claude-resume-picker                    対話モード。選択した sessionId を出力
#   claude-resume-picker archive             アーカイブ専用の対話モード(複数選択可, cldra)
#   claude-resume-picker list [cwd]          fzf 用の一覧を出力 (内部用)
#   claude-resume-picker list-pinned [cwd]   📌のみに絞った一覧を出力 (内部用, Ctrl-P)
#   claude-resume-picker list-archived [cwd] アーカイブ済み一覧を出力 (内部用, Ctrl-R)
#   claude-resume-picker archive-file <jsonl>   1件を .archived/ へ移動 (内部用, Ctrl-X)
#   claude-resume-picker unarchive-file <jsonl> .archived/ から元の場所へ戻す (内部用)
#   claude-resume-picker preview <jsonl>     プレビュー本文を出力 (内部用)
#
# アーカイブは Claude Code 純正機能ではなく自作の規約: セッション jsonl を
# 同一プロジェクトディレクトリ内の .archived/ サブフォルダへ移動するだけ。
# list 系は -maxdepth 1 で探索するため、移動するだけで一覧から隠れる
# (cldr の一覧からも `claude --resume` の対象からも外れる)。mv なので可逆。
set -euo pipefail

PROJECTS_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/projects"

# cwd -> プロジェクトディレクトリ(絶対パス)。英数字以外を - に置換。
project_dir() {
  printf '%s/%s' "$PROJECTS_DIR" "$(printf '%s' "$1" | sed 's/[^a-zA-Z0-9]/-/g')"
}

# 1セッション(jsonl)の表示ラベル「[branch] タイトル」を取り出す。
# タイトルは customTitle(ユーザー命名,📌付き) → ai-title → 最初の発言 → 最終プロンプト。
session_meta() {
  jq -rs '
    def clean: gsub("[\n\t]+";" ");
    (map(select(.type=="custom-title").customTitle)|map(select(. != null and . != ""))|last) as $ct
    | (map(select(.type=="ai-title").aiTitle)|last) as $t
    | (map(select(.type=="last-prompt").lastPrompt)|last) as $lp
    | (map(select(.gitBranch!=null).gitBranch)|last) as $br
    | (map(select(.type=="user")
          | .message.content
          | if type=="string" then .
            else (map(select(.type=="text") | .text? // "")|join(" ")) end)
       | map(select(. != null and . != "" and (startswith("<")|not)))
       | .[0]) as $u
    | (if $ct != null then "📌 " + $ct else ($t // $u // $lp // "(untitled)") end) as $title
    | ("[" + ($br // "-") + "] " + $title | clean)
  ' "$1" 2>/dev/null
}

# 指定ディレクトリ直下(-maxdepth 1)の jsonl を一覧化する。各行: <jsonlパス>\t<日時>\t<ラベル>
list_sessions_in_dir() {
  local dir="$1" f epoch disp label
  [ -d "$dir" ] || return 0
  find "$dir" -maxdepth 1 -name '*.jsonl' -type f 2>/dev/null | while IFS= read -r f; do
    [ -s "$f" ] || continue
    epoch=$(stat -f '%m' "$f")
    disp=$(stat -f '%Sm' -t '%m/%d %H:%M' "$f")
    label=$(session_meta "$f")
    [ -z "$label" ] && label="(untitled)"
    printf '%s\t%s\t%s\t%s\n' "$epoch" "$f" "$disp" "$label"
  done | sort -t$'\t' -k1,1nr | cut -f2-
}

# fzf 用の一覧を出力する(アクティブなセッションのみ、.archived/ は含まない)。
cmd_list() {
  local base="${1:-$PWD}"
  list_sessions_in_dir "$(project_dir "$base")"
}

# アーカイブ済み(.archived/配下)の一覧を出力する。
cmd_list_archived() {
  local base="${1:-$PWD}"
  list_sessions_in_dir "$(project_dir "$base")/.archived"
}

# 1件を .archived/ へ移動する。
cmd_archive_file() {
  local f="$1"
  [ -f "$f" ] || { echo "not found: $f" >&2; return 1; }
  local dir archdir
  dir="$(dirname "$f")"
  archdir="$dir/.archived"
  mkdir -p "$archdir"
  mv "$f" "$archdir/"
}

# .archived/ 配下の1件を親ディレクトリ(元の場所)へ戻す。
cmd_unarchive_file() {
  local f="$1"
  [ -f "$f" ] || { echo "not found: $f" >&2; return 1; }
  local archdir dir
  archdir="$(dirname "$f")"
  dir="$(dirname "$archdir")"
  mv "$f" "$dir/"
}

# プレビュー本文(会話のトランスクリプト)を Markdown で出力。
# glow の全文描画は重い(数千行で1秒超)ため、先頭をすぐ描画し残りを後追いで描画する。
# fzf は preview の出力をストリーム表示するので、2回に分けて流すと体感が大きく速くなる。
# 行数で切るとコードブロック途中で崩れるので、メッセージ境界(👦/🤖 行)で分割する。
PREVIEW_HEAD_LINES=100
cmd_preview() {
  local f="$1"
  [ -s "$f" ] || { echo "(no content)"; return; }
  local md
  md=$(jq -r '
    select(.type=="user" or .type=="assistant")
    | (.message.role) as $role
    | (.message.content) as $c
    | (if ($c|type)=="string" then $c
       elif ($c|type)=="array" then
         [ $c[] | if .type=="text" then .text
                  elif .type=="tool_use" then "🔧 **"+(.name//"tool")+"**"
                  else empty end ] | join("\n\n")
       else "" end) as $text
    | select(($text|type)=="string" and $text != ""
             and ($text|ltrimstr(" ")|startswith("<")|not))
    | "\n" + (if $role=="user" then "👦 " else "🤖 " end) + $text
  ' "$f" 2>/dev/null)
  [ -z "$md" ] && { jq -r '.' "$f" 2>/dev/null; return; }

  # PREVIEW_HEAD_LINES 行以降で最初のメッセージ境界(👦/🤖 行)を分割点にする。
  local split
  split=$(printf '%s\n' "$md" \
    | grep -nE '^(👦|🤖)' \
    | awk -F: -v n="$PREVIEW_HEAD_LINES" '$1>n {print $1-1; exit}')

  if [ -n "$split" ]; then
    # head/tail はパイプを早期クローズし printf に SIGPIPE を起こす(pipefail+set -e で中断)。
    # sed は stdin を読み切るので安全。
    printf '%s\n' "$md" | sed -n "1,${split}p"        | fzf-preview -  # 先頭: 即描画
    printf '%s\n' "$md" | sed -n "$((split+1)),\$p"   | fzf-preview -  # 残り: 後追い描画
  else
    printf '%s\n' "$md" | fzf-preview -
  fi
}

# 一覧のうちピン留め(📌)されたものだけを出力する (list コマンドの3列目=labelで絞り込み)。
cmd_list_pinned() {
  cmd_list "${1:-$PWD}" | awk -F'\t' '$3 ~ /📌/'
}

# 対話モード。選択した sessionId を出力する。
cmd_interactive() {
  local self="$0"
  local fzf_opts=(
    --ansi
    --delimiter='\t'
    --with-nth='2..'
    --no-multi
    --prompt='resume> '
    --header='Enter: resume / Ctrl-P: 📌のみ / Ctrl-A: 全件 / Ctrl-X: アーカイブ / Ctrl-R: アーカイブ一覧(復元)'
    --preview="$self preview {1}"
    --preview-window='right,50%,border-left,wrap,follow'
    --bind="ctrl-p:reload($self list-pinned '$PWD')+change-prompt(📌resume> )"
    --bind="ctrl-a:reload($self list '$PWD')+change-prompt(resume> )"
    --bind="ctrl-x:execute-silent($self archive-file {1})+reload($self list '$PWD')"
    --bind="ctrl-r:reload($self list-archived '$PWD')+change-prompt(📦archived(復元)> )"
  )
  [ -n "${TMUX:-}" ] && fzf_opts+=(--tmux 'center,90%,90%')

  local sel file
  sel=$(cmd_list "$PWD" | fzf "${fzf_opts[@]}") || return 0
  [ -z "$sel" ] && return 0
  file=${sel%%$'\t'*}
  # アーカイブ一覧(.archived/)から選んだ場合は、resume前に元の場所へ戻す。
  if [[ "$file" == */.archived/*.jsonl ]]; then
    "$self" unarchive-file "$file"
    file="$(dirname "$(dirname "$file")")/$(basename "$file")"
  fi
  basename "$file" .jsonl
}

# アーカイブ専用の対話モード(cldra)。Tab で複数選択し、Enter でまとめてアーカイブする。
cmd_interactive_archive() {
  local self="$0"
  local fzf_opts=(
    --ansi
    --delimiter='\t'
    --with-nth='2..'
    --multi
    --prompt='archive> '
    --header='Tab: 複数選択 / Enter: 選択したセッションをアーカイブ / Ctrl-P: 📌のみ / Ctrl-A: 全件'
    --preview="$self preview {1}"
    --preview-window='right,50%,border-left,wrap,follow'
    --bind="ctrl-p:reload($self list-pinned '$PWD')+change-prompt(📌archive> )"
    --bind="ctrl-a:reload($self list '$PWD')+change-prompt(archive> )"
  )
  [ -n "${TMUX:-}" ] && fzf_opts+=(--tmux 'center,90%,90%')

  local sel line file
  sel=$(cmd_list "$PWD" | fzf "${fzf_opts[@]}") || return 0
  [ -z "$sel" ] && return 0
  while IFS= read -r line; do
    file=${line%%$'\t'*}
    [ -n "$file" ] && cmd_archive_file "$file"
  done <<< "$sel"
  echo "アーカイブしました:" >&2
  printf '%s\n' "$sel" | cut -f3- >&2
}

case "${1:-}" in
  list) shift; cmd_list "$@" ;;
  list-pinned) shift; cmd_list_pinned "$@" ;;
  list-archived) shift; cmd_list_archived "$@" ;;
  archive-file) shift; cmd_archive_file "$@" ;;
  unarchive-file) shift; cmd_unarchive_file "$@" ;;
  archive) cmd_interactive_archive ;;
  preview) shift; cmd_preview "$@" ;;
  *) cmd_interactive ;;
esac
